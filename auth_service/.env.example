# ============================================================================
# Django Settings
# ============================================================================
# Secret key for Django (generate a strong one for production)
# You can generate one using: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-super-secret-key-change-this-in-production

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts for the application (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
DB_NAME=auth_service_db
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=localhost
DB_PORT=5432
DB_HOST_PROD=db  # Use 'db' when running in Docker Compose

# ============================================================================
# Server Configuration
# ============================================================================
# Port on which the Django application will run
PORT=8000

# Base route for reverse proxy (nginx)
# Set to empty string if not using a reverse proxy
BASE_ROUTE=/auth

# ============================================================================
# CSRF and Security Settings
# ============================================================================
# Trusted origins for CSRF (comma-separated)
# Add your frontend URLs here
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://localhost:3000


# JWT Configuration
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ISSUER=auth-service
JWT_ALGORITHM=RS256
JWT_AUDIENCE=journies-services
JWT_KID=auth-service-key
AUTH_SERVICE_URL=http://localhost:8001

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# Redis Configuration (Pub/Sub for Data Sync)
# ============================================================================
# Redis host (use 'redis' when running in Docker Compose)
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis database number
REDIS_DB=0

# Redis Streams for publishing events (persistent)
REDIS_STREAM_USERS=journies:stream:users

# Decrypt Password
PASSWORD_CRYPT_KEY=your-same-key-as-frontend

# Decrypt Password
PASSWORD_CRYPT_KEY = 00112233445566778899aabbccddeeff
SALT = 0123456789abcdef0123456789abcdef
