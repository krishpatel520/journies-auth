# ============================================================================
# Django Settings
# ============================================================================
# Secret key for Django (generate a strong one for production)
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ============================================================================
# Database Configuration (PostgreSQL) - Auth Service DB
# ============================================================================
DB_NAME=auth_service
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_HOST_PROD=db

# ============================================================================
# RBAC Database Configuration (rbac_project)
# ============================================================================
# This is the shared centrally-managed RBAC database used by all journies microservices.
RBAC_DB_NAME=rbac_project
RBAC_DB_USER=postgres
RBAC_DB_PASSWORD=your_db_password
RBAC_DB_HOST=localhost
RBAC_DB_PORT=5432

# ============================================================================
# Server Configuration
# ============================================================================
PORT=8001
BASE_ROUTE=

# ============================================================================
# CSRF and Security Settings
# ============================================================================
# Trusted origins for CSRF (comma-separated)
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://localhost:3000

# ============================================================================
# JWT Configuration
# ============================================================================
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ISSUER=auth-service
JWT_ALGORITHM=RS256
JWT_AUDIENCE=journies-services
JWT_KID=auth-service-key
AUTH_SERVICE_URL=http://localhost:8001

LOG_LEVEL=INFO

# ============================================================================
# Redis Configuration (Pub/Sub for Data Sync)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_STREAM_USERS=journies:stream:users

# ============================================================================
# Security & Crypto (Matching Frontend)
# ============================================================================
# AES encryption keys must exactly match the CryptoJS initialization in the frontend map
PASSWORD_CRYPT_KEY=0123456789abcdef0123456789abcdef
SALT=0123456789abcdef0123456789abcdef

# ============================================================================
# Email Configuration
# ============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@domain.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=compass@journies.ai

# ============================================================================
# External Service URLs
# ============================================================================
FRONTEND_URL=http://localhost:3000
COMPASS_SERVICE_URL=http://localhost:3001
LOGO_URL=http://localhost:8001/static/images/Journies_logo.png
